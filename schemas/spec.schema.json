{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "APITesterDefaultsInfo": {
      "properties": {
        "methods": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "auth_modes": {
          "items": {
            "$ref": "#/$defs/AuthMode"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "AuthMethod": {
      "properties": {
        "type": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "token_contains": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "AuthMode": {
      "properties": {
        "name": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "prefix": {
          "type": "string"
        },
        "placeholder": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "AuthenticationInfo": {
      "properties": {
        "type": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "token_contains": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/$defs/AuthMethod"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "BaseURL": {
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "default": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "BodyField": {
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "example": {
          "type": "string"
        },
        "enum": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Allowed values for this field."
        },
        "max_length": {
          "type": "integer",
          "description": "Maximum string length, shown as a constraint."
        },
        "default": {
          "$ref": "#/$defs/Scalar",
          "description": "Default value applied when the field is omitted. May be a string, number, or boolean."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Endpoint": {
      "properties": {
        "name": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "auth": {
          "type": "string"
        },
        "permission": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "note": {
          "type": "string",
          "description": "Caveat shown below the endpoint (e.g. 'unset fields are not updated')."
        },
        "query_params": {
          "items": {
            "$ref": "#/$defs/QueryParam"
          },
          "type": "array"
        },
        "body": {
          "items": {
            "$ref": "#/$defs/BodyField"
          },
          "type": "array"
        },
        "example_body": {
          "type": "string"
        },
        "response": {
          "type": "string",
          "description": "One-line prose description of the response shape."
        },
        "example_response": {
          "type": "string"
        },
        "example_response_authenticated": {
          "type": "string",
          "description": "Example response when the caller is authenticated (for endpoints whose payload differs by auth state)."
        },
        "example_response_public": {
          "type": "string",
          "description": "Example response for an unauthenticated/public caller."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "EventChannel": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable identifier used for anchor links."
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "protocol": {
          "type": "string",
          "description": "Transport: kafka, amqp, mqtt, nats, webhook, sse, websocket, …"
        },
        "address": {
          "type": "string",
          "description": "Protocol-specific address — topic name, queue name, URL."
        },
        "operations": {
          "items": {
            "$ref": "#/$defs/EventOperation"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "title"
      ]
    },
    "EventOperation": {
      "properties": {
        "type": {
          "type": "string",
          "description": "publish or subscribe (from the documented service's perspective)."
        },
        "summary": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "payload": {
          "items": {
            "$ref": "#/$defs/BodyField"
          },
          "type": "array"
        },
        "example": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ]
    },
    "FlowAction": {
      "properties": {
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "field": {
          "type": "string",
          "description": "The request field this action populates (e.g. image_media_id)."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowEdgeInfo": {
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "animated": {
          "type": "boolean"
        },
        "color": {
          "type": "string"
        },
        "style": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowEndpoint": {
      "properties": {
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "content_type": {
          "type": "string"
        },
        "auth": {
          "type": "string"
        },
        "auth_methods": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Accepted auth methods for this step (e.g. [Bearer JWT, X-API-Key])."
        },
        "permission": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/BodyField"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowMethodSteps": {
      "properties": {
        "type": {
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/FlowOverviewStep"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowNodeInfo": {
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Position"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowOverviewInfo": {
      "properties": {
        "methods": {
          "items": {
            "$ref": "#/$defs/FlowMethodSteps"
          },
          "type": "array"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowOverviewStep": {
      "properties": {
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FlowStep": {
      "properties": {
        "step": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "endpoint": {
          "$ref": "#/$defs/FlowEndpoint"
        },
        "actions": {
          "items": {
            "$ref": "#/$defs/FlowAction"
          },
          "type": "array"
        },
        "curl_example": {
          "type": "string"
        },
        "curl_example_jwt": {
          "type": "string"
        },
        "curl_example_api_key": {
          "type": "string"
        },
        "response_example": {
          "type": "string"
        },
        "tip": {
          "type": "string",
          "description": "Highlighted hint shown at the end of the step."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Guide": {
      "properties": {
        "id": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "flow": {
          "items": {
            "$ref": "#/$defs/FlowStep"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "InfoInfo": {
      "properties": {
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "base_urls": {
          "items": {
            "$ref": "#/$defs/BaseURL"
          },
          "type": "array"
        },
        "overview_cards": {
          "items": {
            "$ref": "#/$defs/OverviewCard"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "OverviewCard": {
      "properties": {
        "icon": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PermissionInfo": {
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Position": {
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "QueryParam": {
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "$ref": "#/$defs/Scalar",
          "description": "Default value. May be a string, number, or boolean."
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "Screen": {
      "properties": {
        "id": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "platform": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "calls": {
          "items": {
            "$ref": "#/$defs/ScreenCall"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ScreenCall": {
      "properties": {
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "auth": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "SectionInfo": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "base_urls": {
          "items": {
            "$ref": "#/$defs/BaseURL"
          },
          "type": "array"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/Endpoint"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Theme": {
      "properties": {
        "title": {
          "type": "string",
          "description": "Overrides the title shown in the sidebar and mobile header."
        },
        "logo_icon": {
          "type": "string",
          "description": "Emoji or short string placed before the title."
        },
        "logo_image": {
          "type": "string",
          "description": "URL to a logo image shown in the sidebar header."
        },
        "primary_color": {
          "type": "string",
          "description": "CSS color used for links, buttons, and highlights (overrides --primary)."
        },
        "favicon": {
          "type": "string",
          "description": "Browser favicon URL."
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "properties": {
    "info": {
      "$ref": "#/$defs/InfoInfo",
      "description": "Document metadata (title, version, base URLs, overview cards)."
    },
    "authentication": {
      "$ref": "#/$defs/AuthenticationInfo",
      "description": "Authentication methods accepted by the API."
    },
    "flow_overview": {
      "$ref": "#/$defs/FlowOverviewInfo",
      "description": "High-level auth/flow walkthrough shown on the overview page."
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/SectionInfo"
      },
      "type": "array",
      "description": "Endpoint groupings. Each section may override the document-level base URL."
    },
    "guides": {
      "items": {
        "$ref": "#/$defs/Guide"
      },
      "type": "array",
      "description": "Step-by-step flows that span multiple endpoints (e.g. file upload)."
    },
    "screens": {
      "items": {
        "$ref": "#/$defs/Screen"
      },
      "type": "array",
      "description": "Frontend/mobile screens and the API calls they make."
    },
    "permissions": {
      "items": {
        "$ref": "#/$defs/PermissionInfo"
      },
      "type": "array",
      "description": "Permission names and descriptions referenced by endpoints."
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Free-form rules or invariants of the API."
    },
    "flow_diagram_nodes": {
      "items": {
        "$ref": "#/$defs/FlowNodeInfo"
      },
      "type": "array",
      "description": "Nodes for the ReactFlow architecture diagram."
    },
    "flow_diagram_edges": {
      "items": {
        "$ref": "#/$defs/FlowEdgeInfo"
      },
      "type": "array",
      "description": "Edges for the ReactFlow architecture diagram."
    },
    "api_tester_defaults": {
      "$ref": "#/$defs/APITesterDefaultsInfo",
      "description": "Defaults for the in-browser API tester (HTTP methods, auth modes)."
    },
    "events": {
      "items": {
        "$ref": "#/$defs/EventChannel"
      },
      "type": "array",
      "description": "Async channels/topics the service publishes or consumes (Kafka, AMQP, MQTT, webhooks)."
    },
    "theme": {
      "$ref": "#/$defs/Theme",
      "description": "Branding overrides (title, logo, primary color). All fields optional."
    }
  },
  "additionalProperties": false,
  "type": "object"
}
